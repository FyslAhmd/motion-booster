generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

// ─── USER ─────────────────────────────────────────────

model User {
  id            String     @id @default(cuid())
  username      String     @unique
  email         String     @unique
  fullName      String     @map("full_name")
  phone         String     @unique
  passwordHash  String     @map("password_hash")
  role          UserRole   @default(USER)
  status        UserStatus @default(ACTIVE)
  emailVerified Boolean    @default(false) @map("email_verified")
  avatarUrl     String?    @map("avatar_url")
  adsAccess     Boolean    @default(false) @map("ads_access")
  lastLoginAt   DateTime?  @map("last_login_at")
  lastLoginIp   String?    @map("last_login_ip")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]
  sentMessages     Message[]      @relation("sender")
  conversations    Conversation[] @relation("ConversationParticipants")
  metaAdAssignments MetaAdAssignment[]

  @@index([email])
  @@index([username])
  @@index([phone])
  @@map("users")
}

// ─── REFRESH TOKENS ───────────────────────────────────

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  familyId  String   @map("family_id")
  isRevoked Boolean  @default(false) @map("is_revoked")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([familyId])
  @@map("refresh_tokens")
}

// ─── CONVERSATIONS ────────────────────────────────────

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  FILE
  VOICE
}

model Conversation {
  id           String    @id @default(cuid())
  participants User[]    @relation("ConversationParticipants")
  messages     Message[]
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("conversations")
}

// ─── MESSAGES ─────────────────────────────────────────

model Message {
  id             String        @id @default(cuid())
  conversationId String        @map("conversation_id")
  senderId       String        @map("sender_id")
  content        String
  messageType    MessageType   @default(TEXT) @map("message_type")
  fileUrl        String?       @map("file_url")
  fileName       String?       @map("file_name")
  fileSize       Int?          @map("file_size")
  mimeType       String?       @map("mime_type")
  duration       Int?          // Voice message duration in seconds
  status         MessageStatus @default(SENT)
  createdAt      DateTime      @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

// ─── CMS: HERO SLIDES ────────────────────────────────

model HeroSlide {
  id          String   @id @default(cuid())
  image       String
  customImage String?  @map("custom_image") @db.Text
  title       String
  description String
  badge       String?
  ctaText     String?  @map("cta_text")
  ctaLink     String?  @map("cta_link")
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("hero_slides")
}

// ─── CMS: SERVICE CATEGORIES ─────────────────────────

model ServiceCategory {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  iconType  String   @map("icon_type")
  iconColor String   @map("icon_color")
  iconBg    String   @map("icon_bg")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("service_categories")
}

// ─── CMS: SITE SETTINGS (Welcome Popup, etc.) ────────

model SiteSettings {
  id                    String   @id @default("default")
  welcomeModalImage     String?  @map("welcome_modal_image") @db.Text
  welcomeModalTitle     String?  @map("welcome_modal_title")
  welcomeModalBody      String?  @map("welcome_modal_body") @db.Text
  welcomeModalExploreLink String? @map("welcome_modal_explore_link")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

// ─── CMS: POPULAR SERVICES ───────────────────────────

model PopularService {
  id          String   @id @default(cuid())
  title       String
  description String
  gradient    String
  category    String
  slug        String   @unique
  image       String
  customImage String?  @map("custom_image") @db.Text
  services    String[]
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("popular_services")
}

// ─── CMS: STATS ──────────────────────────────────────────────────────────────

model Stat {
  id          String   @id @default(cuid())
  value       String
  title       String
  description String   @db.Text
  bgColor     String   @map("bg_color")
  valueColor  String   @map("value_color")
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("stats")
}

// ─── CMS: PORTFOLIO ──────────────────────────────────────────────────────────

model PortfolioItem {
  id          String   @id @default(cuid())
  title       String
  category    String
  description String   @db.Text
  client      String
  result      String
  tags        String[]
  coverColor  String   @map("cover_color")
  coverImage  String?  @map("cover_image") @db.Text
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("portfolio_items")
}

// ─── CMS: TESTIMONIALS ───────────────────────────────────────────────────────

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  role        String
  avatar      String
  avatarBg    String   @map("avatar_bg")
  avatarImage String?  @map("avatar_image") @db.Text
  rating      Int      @default(5)
  review      String   @db.Text
  service     String
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("testimonials")
}

// ─── CMS: TEAM MEMBERS ───────────────────────────────────────────────────────

model TeamMember {
  id              String   @id @default(cuid())
  name            String
  role            String
  experience      String
  projects        String
  department      String
  featured        Boolean  @default(false)
  avatar          String
  avatarColor     String   @map("avatar_color")
  avatarImage     String?  @map("avatar_image") @db.Text
  workExperience  String[] @map("work_experience")
  specializedArea String[] @map("specialized_area")
  education       String[]
  workPlaces      String[] @map("work_places")
  order           Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("team_members")
}

// ─── CMS: SERVICES (Homepage "Our Services" section) ─────────────────────────

model Service {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  iconColor   String   @map("icon_color")
  iconType    String   @map("icon_type")
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("services")
}

// ─── CMS: FAQ ────────────────────────────────────────────────────────────────

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("faqs")
}

// ─── CMS: COMPANIES (Trusted by Top Companies marquee) ───────────────────────

model Company {
  id          String   @id @default(cuid())
  name        String
  logoImage   String?  @map("logo_image") @db.Text
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("companies")
}

// ─── CMS: BLOG POSTS ─────────────────────────────────────────────────────────

enum BlogStatus {
  DRAFT
  PUBLISHED
}

model BlogPost {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  excerpt     String     @db.Text
  content     String     @db.Text
  coverImage  String?    @map("cover_image") @db.Text
  category    String
  tags        String[]
  author      String     @default("Motion Booster")
  status      BlogStatus @default(DRAFT)
  order       Int        @default(0)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@index([slug])
  @@index([status])
  @@map("blog_posts")
}

// ─── META AD ASSIGNMENTS ──────────────────────────────
// Tracks which Meta campaign / ad set / ad is assigned to which user.
// One Meta entity can be assigned to at most one user (unique on metaObjectId).

enum MetaObjectType {
  CAMPAIGN
  ADSET
  AD
}

model MetaAdAssignment {
  id             String         @id @default(cuid())
  metaObjectId   String         @unique @map("meta_object_id")   // Facebook API id (campaign, adset, or ad)
  metaObjectType MetaObjectType @map("meta_object_type")
  metaAccountId  String         @map("meta_account_id")          // e.g. act_xxxxx
  userId         String         @map("user_id")
  assignedAt     DateTime       @default(now()) @map("assigned_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([metaAccountId])
  @@index([metaObjectType, metaAccountId])
  @@map("meta_ad_assignments")
}
