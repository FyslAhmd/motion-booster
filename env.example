JWT_REFRESH_EXPIRY="7d"

# ─── APP ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── CLOUDINARY ──────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# META API CONFIGURATION
META_APP_ID=""
META_AD_ACCOUNT_ID=""
