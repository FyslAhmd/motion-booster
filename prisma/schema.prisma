generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

// ─── USER ─────────────────────────────────────────────

model User {
  id            String     @id @default(cuid())
  username      String     @unique
  email         String     @unique
  fullName      String     @map("full_name")
  phone         String     @unique
  passwordHash  String     @map("password_hash")
  role          UserRole   @default(USER)
  status        UserStatus @default(ACTIVE)
  emailVerified Boolean    @default(false) @map("email_verified")
  avatarUrl     String?    @map("avatar_url")
  adsAccess     Boolean    @default(false) @map("ads_access")
  lastLoginAt   DateTime?  @map("last_login_at")
  lastLoginIp   String?    @map("last_login_ip")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]
  sentMessages     Message[]      @relation("sender")
  conversations    Conversation[] @relation("ConversationParticipants")
  metaAdAssignments MetaAdAssignment[]
  boostRequests     BoostRequest[]
  budgetDeposits    UserBudgetDeposit[] @relation("BudgetDepositsForUser")
  budgetEntriesCreated UserBudgetDeposit[] @relation("BudgetDepositsCreatedByAdmin")
  activityHistory     ActivityHistory[]

  @@index([email])
  @@index([username])
  @@index([phone])
  @@map("users")
}

// ─── ACTIVITY HISTORY ─────────────────────────────────

model ActivityHistory {
  id          String   @id @default(cuid())
  userId      String?  @map("user_id")
  eventType   String   @map("event_type")
  action      String
  path        String?  @db.Text
  method      String?  @db.VarChar(10)
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent") @db.Text
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("activity_history")
}

// ─── USER BUDGET DEPOSIT HISTORY ─────────────────────

model UserBudgetDeposit {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  amount      Decimal  @db.Decimal(14, 2)
  note        String?  @db.Text
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user      User  @relation("BudgetDepositsForUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy User? @relation("BudgetDepositsCreatedByAdmin", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdById])
  @@index([createdAt])
  @@map("user_budget_deposits")
}

// ─── REFRESH TOKENS ───────────────────────────────────

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  familyId  String   @map("family_id")
  isRevoked Boolean  @default(false) @map("is_revoked")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([familyId])
  @@map("refresh_tokens")
}

// ─── CONVERSATIONS ────────────────────────────────────

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  FILE
  VOICE
}

model Conversation {
  id           String    @id @default(cuid())
  participants User[]    @relation("ConversationParticipants")
  messages     Message[]
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("conversations")
}

// ─── MESSAGES ─────────────────────────────────────────

model Message {
  id             String        @id @default(cuid())
  conversationId String        @map("conversation_id")
  senderId       String        @map("sender_id")
  content        String
  messageType    MessageType   @default(TEXT) @map("message_type")
  fileUrl        String?       @map("file_url")
  fileName       String?       @map("file_name")
  fileSize       Int?          @map("file_size")
  mimeType       String?       @map("mime_type")
  duration       Int?          // Voice message duration in seconds
  status         MessageStatus @default(SENT)
  createdAt      DateTime      @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

// ─── CONTACT MESSAGES ───────────────────────────────

model ContactMessage {
  id          String   @id @default(cuid())
  fullName    String   @map("full_name")
  email       String
  companyName String?  @map("company_name")
  mobile      String
  queryDetails String  @map("query_details") @db.Text
  source      String   @default("CONTACT_US")
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@index([isRead])
  @@map("contact_messages")
}

// ─── CMS: HERO SLIDES ────────────────────────────────

model HeroSlide {
  id          String   @id @default(cuid())
  image       String
  customImage String?  @map("custom_image") @db.Text
  title       String
  titleBn     String?  @map("title_bn")
  description String
  descriptionBn String? @map("description_bn")
  badge       String?
  badgeBn     String?  @map("badge_bn")
  ctaText     String?  @map("cta_text")
  ctaTextBn   String?  @map("cta_text_bn")
  ctaLink     String?  @map("cta_link")
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("hero_slides")
}

// ─── CMS: SERVICE CATEGORIES ─────────────────────────

model ServiceCategory {
  id        String   @id @default(cuid())
  title     String
  titleBn   String?  @map("title_bn")
  slug      String   @unique
  iconType  String   @map("icon_type")
  iconColor String   @map("icon_color")
  iconBg    String   @map("icon_bg")
  logoImage String?  @map("logo_image") @db.Text
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("service_categories")
}

// ─── CMS: SITE SETTINGS (Welcome Popup, etc.) ────────

model SiteSettings {
  id                    String   @id @default("default")
  welcomeModalImage     String?  @map("welcome_modal_image") @db.Text
  welcomeModalTitle     String?  @map("welcome_modal_title")
  welcomeModalBody      String?  @map("welcome_modal_body") @db.Text
  welcomeModalExploreLink String? @map("welcome_modal_explore_link")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

// ─── CMS: POPULAR SERVICES ───────────────────────────

model PopularService {
  id          String   @id @default(cuid())
  title       String
  titleBn     String?  @map("title_bn")
  description String
  descriptionBn String? @map("description_bn")
  gradient    String
  category    String
  categoryBn  String?  @map("category_bn")
  slug        String   @unique
  image       String
  customImage String?  @map("custom_image") @db.Text
  services    String[]
  servicesBn  String[] @default([]) @map("services_bn")
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("popular_services")
}

// ─── CMS: STATS ──────────────────────────────────────────────────────────────

model Stat {
  id          String   @id @default(cuid())
  value       String
  title       String
  titleBn     String?  @map("title_bn")
  description String   @db.Text
  descriptionBn String? @map("description_bn") @db.Text
  bgColor     String   @map("bg_color")
  valueColor  String   @map("value_color")
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("stats")
}

// ─── CMS: PORTFOLIO ──────────────────────────────────────────────────────────

model PortfolioItem {
  id          String   @id @default(cuid())
  title       String
  titleBn     String?  @map("title_bn")
  category    String
  categoryBn  String?  @map("category_bn")
  description String   @db.Text
  descriptionBn String? @map("description_bn") @db.Text
  client      String
  clientBn    String?  @map("client_bn")
  result      String
  resultBn    String?  @map("result_bn")
  tags        String[]
  tagsBn      String[] @default([]) @map("tags_bn")
  coverColor  String   @map("cover_color")
  coverImage  String?  @map("cover_image") @db.Text
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("portfolio_items")
}

// ─── CMS: TESTIMONIALS ───────────────────────────────────────────────────────

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  role        String
  roleBn      String?  @map("role_bn")
  avatar      String
  avatarBg    String   @map("avatar_bg")
  avatarImage String?  @map("avatar_image") @db.Text
  rating      Int      @default(5)
  review      String   @db.Text
  reviewBn    String?  @map("review_bn") @db.Text
  service     String
  serviceBn   String?  @map("service_bn")
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("testimonials")
}

// ─── CMS: TEAM MEMBERS ───────────────────────────────────────────────────────

model TeamMember {
  id              String   @id @default(cuid())
  name            String
  role            String
  roleBn          String?  @map("role_bn")
  experience      String
  experienceBn    String?  @map("experience_bn")
  projects        String
  projectsBn      String?  @map("projects_bn")
  department      String
  departmentBn    String?  @map("department_bn")
  featured        Boolean  @default(false)
  avatar          String
  avatarColor     String   @map("avatar_color")
  avatarImage     String?  @map("avatar_image") @db.Text
  workExperience  String[] @map("work_experience")
  workExperienceBn String[] @default([]) @map("work_experience_bn")
  specializedArea String[] @map("specialized_area")
  specializedAreaBn String[] @default([]) @map("specialized_area_bn")
  education       String[]
  educationBn     String[] @default([]) @map("education_bn")
  workPlaces      String[] @map("work_places")
  workPlacesBn    String[] @default([]) @map("work_places_bn")
  order           Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("team_members")
}

// ─── CMS: SERVICES (Homepage "Our Services" section) ─────────────────────────

model Service {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  iconColor   String   @map("icon_color")
  iconType    String   @map("icon_type")
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("services")
}

// ─── CMS: FAQ ────────────────────────────────────────────────────────────────

model FAQ {
  id        String   @id @default(cuid())
  question  String
  questionBn String? @map("question_bn")
  answer    String   @db.Text
  answerBn  String?  @map("answer_bn") @db.Text
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("faqs")
}

// ─── CMS: COMPANIES (Trusted by Top Companies marquee) ───────────────────────

model Company {
  id          String   @id @default(cuid())
  name        String
  logoImage   String?  @map("logo_image") @db.Text
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("companies")
}

// ─── CMS: BLOG POSTS ─────────────────────────────────────────────────────────

enum BlogStatus {
  DRAFT
  PUBLISHED
}

model BlogPost {
  id          String     @id @default(cuid())
  title       String
  titleBn     String?    @map("title_bn")
  slug        String     @unique
  excerpt     String     @db.Text
  excerptBn   String?    @map("excerpt_bn") @db.Text
  content     String     @db.Text
  contentBn   String?    @map("content_bn") @db.Text
  coverImage  String?    @map("cover_image") @db.Text
  category    String
  categoryBn  String?    @map("category_bn")
  tags        String[]
  tagsBn      String[]   @default([]) @map("tags_bn")
  author      String     @default("Motion Booster")
  status      BlogStatus @default(DRAFT)
  order       Int        @default(0)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@index([slug])
  @@index([status])
  @@map("blog_posts")
}

// ─── META AD ASSIGNMENTS ──────────────────────────────
// Tracks which Meta campaign / ad set / ad is assigned to which user.
// One Meta entity can be assigned to at most one user (unique on metaObjectId).

enum MetaObjectType {
  CAMPAIGN
  ADSET
  AD
}

model MetaAdAssignment {
  id             String         @id @default(cuid())
  metaObjectId   String         @unique @map("meta_object_id")   // Facebook API id (campaign, adset, or ad)
  metaObjectType MetaObjectType @map("meta_object_type")
  metaAccountId  String         @map("meta_account_id")          // e.g. act_xxxxx
  userId         String         @map("user_id")
  assignedAt     DateTime       @default(now()) @map("assigned_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([metaAccountId])
  @@index([metaObjectType, metaAccountId])
  @@map("meta_ad_assignments")
}

// ─── BOOST REQUESTS (Ad boost form submissions from chat) ────────────────────

model BoostRequest {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  language       String   @default("en")          // "en" | "bn"
  postLink       String   @map("post_link") @db.Text
  totalBudget    String   @map("total_budget")
  dailyBudget    String   @map("daily_budget")
  targetAudience String   @map("target_audience") @db.Text
  completed      Boolean  @default(false)
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("boost_requests")
}
